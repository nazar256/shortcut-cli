# Shortcut CLI Environment Variables
# Copy this file to .env in the directory where you run the CLI, or export these variables.

# Required: Your Shortcut API token.
# You can generate one at https://app.shortcut.com/settings/account/api-tokens
SHORTCUT_API_TOKEN=your_api_token_here

# Optional: Override the Shortcut API base URL.
# SHORTCUT_BASE_URL=https://api.app.shortcut.com

# Optional: Override HTTP timeout duration.
# SHORTCUT_TIMEOUT=30s
